# LTA Datamall API key — register at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_API_KEY=your_lta_api_key_here

# Database (SQLite by default; swap for PostgreSQL: postgresql://user:pass@host/db)
DATABASE_URL=sqlite:///./bus_data.db

# How often to collect data from LTA API (minutes)
COLLECTION_INTERVAL_MINUTES=5

# How often to retrain the ML model (hours)
MODEL_RETRAIN_INTERVAL_HOURS=1

# Comma-separated list of bus stop codes to monitor at startup
MONITORED_STOPS=83139,83141,84009,01012,01013
